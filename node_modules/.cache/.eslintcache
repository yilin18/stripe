.log(\"error creating the user\", err.message)\r\n    }\r\n  }\r\n\r\n  return userDocRef\r\n\r\n}","C:\\code\\react\\Stripe\\src\\Component\\category-item\\category-item.component.jsx",["59"],[],"import \"./category-item.styles.scss\"\r\nimport { Component } from \"react\"\r\n\r\nconst CategoryItem = ({category})=>{\r\n\r\n    return (\r\n        <div className='category-container'>\r\n            <div className='background-image' style={{\r\n                backgroundImage: `url(${category.imageUrl})`\r\n                }}/>\r\n            <div className='category-body-container'>\r\n                <h2>{category.title}</h2>\r\n                <p>Shop Now</p>\r\n            </div>\r\n        </div>\r\n      )\r\n}\r\n\r\nexport default CategoryItem\r\n    ",{"ruleId":"60","severity":1,"message":"61","line":1,"column":10,"nodeType":"62","messageId":"63","endLine":1,"endColumn":15},{"ruleId":"60","severity":1,"message":"64","line":2,"column":10,"nodeType":"62","messageId":"63","endLine":2,"endColumn":19},{"ruleId":"60","severity":1,"message":"65","line":4,"column":5,"nodeType":"62","messageId":"63","endLine":4,"endColumn":9},{"ruleId":"60","severity":1,"message":"66","line":27,"column":7,"nodeType":"62","messageId":"63","endLine":27,"endColumn":18},{"ruleId":"60","severity":1,"message":"67","line":2,"column":10,"nodeType":"62","messageId":"63","endLine":2,"endColumn":19},"no-unused-vars","'async' is defined but never used.","Identifier","unusedVar","'useEffect' is defined but never used.","'auth' is defined but never used.","'firebaseapp' is assigned a value but never used.","'Component' is defined but never used."]